import numpy as np
import pandas as pd

def bai1():
    a = np.random.randint(0, 21, (3, 3))
    print(a)
    print("Tất cả khác 0:", np.all(a != 0))

def bai2():
    b = np.random.randint(0, 21, (3, 3))
    print(b)
    print("Có phần tử = 0:", np.any(b == 0))

def bai3():
    x = np.array([1, 2, 3])
    y = np.array([2, 2, 1])
    print(np.greater(x, y))
    print(np.less(x, y))

def bai4():
    print(np.array([1]*10 + [0]*10 + [5]*5))

def bai5():
    arr = np.arange(30, 71)
    print(arr[arr % 2 == 0])

def bai6():
    print(np.identity(3))

def bai7():
    arr = np.random.randint(15, 56, 10)
    print(arr)
    print(arr[1:-1])

def bai8():
    arr = np.random.randint(0, 21, 20)
    arr[(arr >= 9) & (arr <= 15)] *= -1
    print(arr)

def bai9():
    print(np.random.randint(10, 22, (3, 4)))

def bai10():
    arr = np.ones((10, 10))
    arr[1:-1, 1:-1] = 0
    print(arr)

def bai11():
    print(np.diag([1, 2, 3, 4, 5]))

def bai12():
    arr = np.random.randint(0, 10, (3, 3))
    print(arr)
    print(arr.sum(axis=1))
    print(arr.sum(axis=0))

def bai13():
    v1 = np.random.randint(0, 10, 10)
    v2 = np.random.randint(0, 10, 10)
    print(np.dot(v1, v2))

def bai14():
    A = np.random.randint(0, 10, (4, 3))
    y = np.random.randint(0, 10, 3)
    print(A + y)

def bai15():
    s1 = pd.Series([2, 4, 6, 8, 10])
    s2 = pd.Series([1, 3, 5, 7, 10])
    print(s1 + s2)

def bai16():
    df = pd.DataFrame({
        'col1': [1,2,3,4,7,11],
        'col2': [0,5,6,9,5,0],
        'col3': [7,5,8,12,1,11]
    })
    print(df.iloc[:,0])

def bai17():
    df = pd.DataFrame(np.random.randint(0,50,(4,3)), columns=['A','B','C'])
    print(df.sort_values(by='A'))

def bai18():
    s = pd.Series([1,2,3,4,5], index=list('ABCDE'))
    print(s.reindex(['B','A','C','D','E']))

def bai19():
    sr1 = pd.Series([1,2,3,4,5])
    sr2 = pd.Series([2,4,6,8,10])
    print(sr1[~sr1.isin(sr2)])

def bai20():
    x = np.random.randint(0,20,20)
    y = np.random.randint(0,20,20)
    print("Union:", np.union1d(x,y))
    print("Intersection:", np.intersect1d(x,y))

def bai21():
    s1 = pd.Series([1,2,7,8,9])
    s2 = pd.Series(['p','q','r','w','x'])
    print(pd.concat([s1,s2]))
    print(pd.concat([s1,s2], axis=1))

def bai22_30():
    df = pd.DataFrame({
        'name': ['Anastasia','Dima','Katherine','James','Emily',
                 'Michael','Matthew','Laura','Kevin','Jonas'],
        'score': [12.5,9,16.5,None,9,20,14.5,None,8,19],
        'attempts': [1,3,2,3,1,1,2,3,1,2],
        'qualify': ['yes','no','yes','no','yes',
                    'yes','no','no','yes','yes']
    }, index=list('abcdefghij'))

    print("22:\n", df)
    print("23:\n", df.head(3))
    print("24:\n", df[['name','score']])
    print("25:\n", df[df['attempts'] > 2])
    print("26:", df.shape)
    print("27:\n", df[df['score'].isna()])
    print("28:\n", df[df['score'].between(15,20)])
    print("29:\n", df[(df['attempts'] > 2) & (df['score'] > 15)])

    df.loc['d','score'] = 19
    print("30:\n", df)
