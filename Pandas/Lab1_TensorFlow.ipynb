import tensorflow as tf

def bai1():
    return tf.zeros([2, 3])

def bai2():
    X = tf.constant([[1, 2, 3], [4, 5, 6]])
    return tf.zeros_like(X)

def bai3():
    return tf.fill([3, 2], 5)

def bai4():
    return tf.range(6, 106, delta=2)[:50]

def bai5():
    return tf.range(10, 101, delta=2)

def bai6():
    return tf.random.normal([3, 2], mean=0, stddev=2)

def bai7():
    return tf.random.uniform([3, 2], minval=0, maxval=2)

def bai8():
    X = tf.constant([[1, 2], [3, 4], [5, 6]])
    return tf.random.shuffle(X)

def bai9():
    t = tf.random.uniform([10, 10, 3])
    return tf.image.random_crop(t, size=[5, 5, 3])

def bai10():
    x = tf.random.uniform([5])
    y = tf.random.uniform([5])
    return tf.where(x < y, x + y, x - y)

def bai11():
    x = tf.random.uniform([3, 2], 5, 10)
    y = tf.random.uniform([2, 3], 15, 20)
    diag = tf.linalg.diag_part(x)
    x_diag = tf.linalg.diag(diag)
    x_pad = tf.pad(x_diag, [[0, 0], [0, 1]])
    y_pad = tf.pad(y, [[1, 0], [0, 0]])
    return x_pad + y_pad

def bai12():
    x = tf.random.uniform((3, 2, 2))
    y = tf.random.uniform((3, 2, 2))
    return x + y, x - y, x * y, x / y

def bai13():
    x = tf.keras.Input(shape=(2,))
    y = tf.keras.Input(shape=(2,))
    model = tf.keras.Model([x, y], x + y)
    return model.summary()

def bai14():
    x = tf.keras.Input(shape=(2,))
    y = tf.keras.Input(shape=(2,))
    model = tf.keras.Model([x, y], [x - y, x * y])
    return model.summary()

def bai15():
    a = tf.keras.Input(shape=(1,))
    b = tf.keras.Input(shape=(1,))
    model = tf.keras.Model([a, b], 2 * (a + b))
    return model.summary()

def bai16():
    a = tf.keras.Input(shape=(1,))
    b = tf.keras.Input(shape=(1,))
    c = tf.keras.Input(shape=(1,))
    model = tf.keras.Model([a, b, c], 2 * (a*b + b*c + a*c))
    return model.summary()

def bai17():
    AD, BC = 5.0, 5.0
    AB, CD = 3.0, 3.0
    return (AD == BC) and (AB == CD)

def bai18():
    AB, CD = 4.0, 4.0
    AD, BC = 6.0, 6.0
    return (AB == CD), (AD == BC)

def bai19():
    A = tf.constant([0.0, 2.0])
    B = tf.constant([0.0, 0.0])
    C = tf.constant([4.0, 0.0])
    M = (A + B) / 2
    N = (A + C) / 2
    NA = tf.norm(N - A)
    NC = tf.norm(N - C)
    return NA.numpy(), NC.numpy()

ds_bai = {
    1: bai1, 2: bai2, 3: bai3, 4: bai4, 5: bai5,
    6: bai6, 7: bai7, 8: bai8, 9: bai9, 10: bai10,
    11: bai11, 12: bai12, 13: bai13, 14: bai14,
    15: bai15, 16: bai16, 17: bai17, 18: bai18, 19: bai19
}

print("\n===== DANH SÁCH BÀI =====")
for i in range(1, 20):
    print("Bài", i)

chon = int(input("\nNhập số bài (1-19): "))

if chon in ds_bai:
    kq = ds_bai[chon]()
    if isinstance(kq, tf.Tensor):
        print(kq.numpy())
    else:
        print(kq)
else:
    print("Chọn sai!")